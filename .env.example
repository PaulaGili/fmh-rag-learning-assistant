ANTHROPIC_API_KEY=your_api_key
AUTH_PASSWORD=your_password

# Required: random salt for session token hashing (PBKDF2, 100k iterations)
# Generate with: openssl rand -hex 32
AUTH_SALT=your_random_salt_here

# Optional: URL of the Python backend (defaults to http://localhost:8000)
# BACKEND_URL=https://your-space.hf.space

# Backend only: allowed CORS origin for the frontend
# FRONTEND_URL=https://your-app.vercel.app

# Optional: override the model used for chat responses
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
