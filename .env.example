ANTHROPIC_API_KEY=your_api_key
AUTH_PASSWORD=your_password

# Optional: custom salt for session token hashing (recommended in production)
# Generate a random value, e.g.: openssl rand -hex 32
AUTH_SALT=your_random_salt_here

# Optional: override the model used for chat responses
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
